{
  "name": "kado",
  "version": "1.0.0",
  "description": "Kado",
  "main": "main.js",
  "author": "buzxce, ravengeance",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "package": "electron-builder --dir",
    "make": "electron-builder --win --x64"
