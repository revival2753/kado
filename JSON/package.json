    "directories": {
      "buildResources": "assets"
    }
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs"
}
